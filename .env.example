# ============================================================
# AGENTROPOLIS OFFGRID NODE — Environment Config
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── Node Identity (auto-generated on install) ─────────────
NODE_ID=node-your-uuid-here
DISTRICT_ID=1
OPERATOR_WALLET=0xYourWalletAddress

# ── AGENTROPOLIS Network ──────────────────────────────────
RELAY_COORDINATOR_URL=https://agentropolis.chaoswired.workers.dev
XENTS_CONTRACT=0x0000000000000000000000000000000000000000

# ── Supabase (Node Registry) ──────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── AI APIs (optional — node works with Ollama only) ──────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── QuickNode RPC (optional — for on-chain reporting) ─────
QUICKNODE_BASE_URL=https://your-endpoint.base-mainnet.quiknode.pro/
QUICKNODE_SOLANA_URL=https://your-endpoint.solana-mainnet.quiknode.pro/
